VITE_SITE_URL=https://exestination.dev
VITE_LEAD_SUBMITTER=api
VITE_LEAD_API_ENDPOINT=/api/leads

# Optional client-side providers
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_FORMSPREE_ENDPOINT=
VITE_TELEGRAM_BOT_ENDPOINT=

# Backend API
PORT=8787
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
TRUST_PROXY=loopback
LEAD_JSON_LIMIT=16kb
LEAD_RATE_LIMIT_MAX=6
LEAD_RATE_LIMIT_WINDOW_MS=900000

# Delivery mode:
# smtp - production email delivery
# file - local fallback into server/data/leads.log
LEAD_DELIVERY_MODE=file
LEAD_TO_EMAIL=exestination@yandex.ru

# SMTP example
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Exestination Studio <no-reply@example.com>"
